.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
runs/
.env

# secrets & local key material — never publish
.secrets/
*.key
**/enrollment.json
**/.corvex/
**/.campaignfuse/

# sealed / held-out eval artifacts — generate locally only
heldout/
*.sealed

# local sandboxes & large media (except published docs/assets)
.sandbox/
*.gif
*.mp4

# allow published demo media in docs
!docs/assets/
!docs/assets/*.mp4
!docs/assets/*.gif

# lab runtime (sources under labs/live are tracked)
labs/live/shared/
labs/**/__pycache__/

# regenerated / machine-local reports (keep RESULTS.md summary only)
reports/dashboard/
reports/daily/
reports/seal-day0.txt
reports/eval-*-console.txt
reports/pytest.txt
reports/stage_d_dry_run.jsonl
reports/prevention_log.jsonl
reports/AUDIT_BENCHMARK.json
reports/oss_retention.json
reports/stranger_dry_run.json
reports/stranger_dry_run.md
reports/stageA.json
reports/stageA.md
reports/stageA_heldout.json
reports/stageA_train.json
reports/stageA_train.md
reports/stageA-gate.txt
reports/stage-b-allowed

